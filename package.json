{
  "name": "adobestocksubmissionmanager",
  "private": true,
  "version": "1.0.0",
  "description": "Adobe Stock Submission Manager",
  "author": "Fazle Rabby",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "dev:electron": "concurrently \"vite --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "archiver": "^5.3.2",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "exiftool-vendored": "^36.0.0",
    "image-size": "^2.0.2",
    "lottie-react": "^2.4.1",
    "node-machine-id": "^1.1.12",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.18.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.fazlerabby.adobestocksubmissionmanager",
    "productName": "AdobeStock Submission Manager",
    "copyright": "Copyright © 2026 Fazle Rabby",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AdobeStock Submission Manager",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
"publish": [
  {
    "provider": "github",
    "owner": "Rabby567",
    "repo": "AdobeStockSubmissionManager"
  }
]

  }
}
